+int hns_roce_lite_alloc_buf(void **buf, unsigned int *length, unsigned int size, unsigned int page_size,
+	unsigned int dev_id)
+{
+	return g_roce_hal_api_ops.hns_roce_hal_alloc_buf(buf, length, size, page_size, dev_id);
+}
