+static void convert_masked_atomic_buf(void *buf, unsigned int len)
+{
+	unsigned int *head;
+	unsigned int *tail;
+	unsigned int data1;
+	unsigned int data2;
+	unsigned int tail_offset = ATOMIC_BUFF_TAIL_OFFSET(len);
+	unsigned int loop_time = ATOMIC_CONVERT_LOOP_TIME(len);
+	int i;
+
+	head = buf;
+	tail = buf + tail_offset;
+
+	data1 = *head;
+	data2 = *tail;
+
+	for (i = 0; i < loop_time; i++) {
+		*head = htonl(data2);
+		*tail = htonl(data1);
+		head++;
+		tail--;
+		data1 = *head;
+		data2 = *tail;
+	 }
+}
+
+static int set_masked_atomic_seg(struct hns_roce_qp *qp, struct ibv_send_wr *wr,
+				 void *dseg, struct hns_roce_sge_info *sge_info)
+{
+	struct hns_roce_wqe_atomic_seg *aseg = dseg;
+	unsigned int data_len = sge_info->total_len;
+	unsigned int opcode = wr->opcode;
+	unsigned int buf_sge_num;
+	void *buf;
+
+	if (wr->num_sge != 1 || !is_atomic(data_len))
+		return -EINVAL;
+
+	aseg->fetchadd_swap_data = 0;
+	aseg->cmp_data = 0;
+
+	/* a buf contains a data and a mask */
+	buf_sge_num = (data_len << 1) >> HNS_ROCE_SGE_SHIFT;
+
+	/* MASK CAS need 2 buf, MASK FAA need 1 buf, just check MASK CAS */
+	if ((buf_sge_num << 1) + HNS_ROCE_SGE_IN_WQE > qp->sq.max_gs)
+		return -EINVAL;
+
+	if (opcode == HNS_ROCE_WR_ATOMIC_MASK_COMP_AND_SWAP) {
+		if (!wr->wr.atomic.swap || !wr->wr.atomic.compare_add)
+			return -EINVAL;
+
+		buf = (void *)(uintptr_t)wr->wr.atomic.swap;
+		convert_masked_atomic_buf(buf, data_len);
+		convert_masked_atomic_buf(buf + data_len, data_len);
+		set_extend_atomic_seg(qp, buf_sge_num, sge_info, buf);
+
+		buf = (void *)(uintptr_t)wr->wr.atomic.compare_add;
+		convert_masked_atomic_buf(buf, data_len);
+		convert_masked_atomic_buf(buf + data_len, data_len);
+		set_extend_atomic_seg(qp, buf_sge_num, sge_info, buf);
+	} else {
+		if (!wr->wr.atomic.compare_add)
+			return -EINVAL;
+
+		buf = (void *)(uintptr_t)wr->wr.atomic.compare_add;
+		convert_masked_atomic_buf(buf, data_len);
+		convert_masked_atomic_buf(buf + data_len, data_len);
+		set_extend_atomic_seg(qp, buf_sge_num, sge_info, buf);
+	}
+
+	return 0;
+}
