+struct ibv_qp *ibv_exp_create_qp(struct ibv_pd *pd, struct ibv_exp_qp_init_attr *qp_init_attr, struct rdma_lite_device_qp_attr *qp_resp)
+{
+    struct hns_roce_context *context = to_hr_ctx(pd->context);
