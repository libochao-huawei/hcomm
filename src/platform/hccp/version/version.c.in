#include <syslog.h>
#include <string.h>
#include <unistd.h>

#ifndef VERSION_LOG_FACILITY
#  define VERSION_LOG_FACILITY @VERSION_LOG_FACILITY@  // 设施: LOG_USER, LOG_DAEMON, LOG_LOCAL0~7
#endif

#ifndef VERSION_LOG_LEVEL
#  define VERSION_LOG_LEVEL    @VERSION_LOG_LEVEL@  // 级别: LOG_INFO, LOG_NOTICE, LOG_DEBUG
#endif

__attribute__((visibility("default"), used))
const char *@SAFE_TARGET_NAME@_version_str[] = 
{
    "=========================================",
    "  @TARGET_SO_NAME@ Version Info",
    "-----------------------------------------",
    "  Version:    @BUILD_VERSION@",
    "  Build Time: @BUILD_TIMESTAMP@ (UTC)",
    "  Compiler:   @COMPILER_INFO@",
    "  Arch:       @TARGET_ARCH@",
    "  Project:    @PROJECT_TYPE@",
    "  Mode:       @RUN_TYPE@",
    @EXTENSION_LINES@
    "=========================================",
    NULL,
};

__attribute__((constructor(200))) //low priority to log after so constructed
static void log_version(void)
{
    pid_t pid = getpid();
    for(const char **str = @SAFE_TARGET_NAME@_version_str; *str != NULL; str++)
    {
        syslog(VERSION_LOG_FACILITY | VERSION_LOG_LEVEL,
            "[HCCP Version] [PID:%d] %s", pid, *str);
    }
}
