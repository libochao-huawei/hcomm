 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/st/roce/rdma_service/tc_ut_rs_ub.c b/st/roce/rdma_service/tc_ut_rs_ub.c
index 029c1a72b..dfc248ab0 100644
--- a/st/roce/rdma_service/tc_ut_rs_ub.c
+++ b/st/roce/rdma_service/tc_ut_rs_ub.c
@@ -1565,11 +1565,11 @@ void tc_rs_epoll_event_jfc_in_handle()
 
 void tc_rs_handle_epoll_poll_jfc()
 {
+    struct ctx_qp_share_info qp_share_info = {0};
     struct rs_ctx_jetty_cb jetty_cb = {0};
     struct rs_ub_dev_cb dev_cb = {0};
     urma_jetty_t jetty = {0};
     urma_jfce_t jfce = {0};
-    uint16_t ci_addr = 0;
     int ret = 0;
 
     jetty_cb.jetty = &jetty;
@@ -1600,7 +1600,7 @@ void tc_rs_handle_epoll_poll_jfc()
     mocker_clean();
 
     jetty_cb.jetty->jetty_id.id = 0;
-    jetty_cb.ci_addr = &ci_addr;
+    jetty_cb.qp_share_info_addr = &qp_share_info;
     RS_INIT_LIST_HEAD(&dev_cb.jetty_list);
     RsListAddTail(&jetty_cb.list, &dev_cb.jetty_list);
     mocker(rs_urma_wait_jfc, 1, 1);
