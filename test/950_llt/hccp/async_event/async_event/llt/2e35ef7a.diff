+void tc_ra_ctx_get_async_events()
+{
+    struct ra_ctx_handle ctx_handle = {0};
+    struct async_event events[1] = {0};
+    unsigned int num = 0;
+    int ret = 0;
+
+    ret = ra_ctx_get_async_events(NULL, NULL, NULL);
+    EXPECT_INT_EQ(ret, 128103);
+
+    ret = ra_ctx_get_async_events(&ctx_handle, NULL, NULL);
+    EXPECT_INT_EQ(ret, 128103);
+
+    ret = ra_ctx_get_async_events(&ctx_handle, events, NULL);
+    EXPECT_INT_EQ(ret, 128103);
+
+    ret = ra_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 128103);
+
+    num = ASYNC_EVENT_MAX_NUM + 1;
+    ret = ra_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 128103);
+
+    num = 1;
+    ret = ra_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 128103);
+
+    ctx_handle.ctx_ops = &g_ra_hdc_ctx_ops;
+    mocker_clean();
+    mocker(ra_hdc_ctx_get_async_events, 1, 0);
+    ret = ra_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 0);
+    mocker_clean();
+
+    mocker(ra_hdc_ctx_get_async_events, 1, -1);
+    ret = ra_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 128100);
+    mocker_clean();
+}
+
+void tc_ra_hdc_ctx_get_async_events()
+{
+    struct ra_ctx_handle ctx_handle = {0};
+    struct async_event events[1] = {0};
+    unsigned int num = 1;
+    int ret = 0;
+
+    mocker_clean();
+    mocker(RaHdcProcessMsg, 1, -1);
+    ret = ra_hdc_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, -1);
+    mocker_clean();
+
+    mocker(RaHdcProcessMsg, 1, 0);
+    ret = ra_hdc_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 0);
+    mocker_clean();
+};
+
+void tc_ra_peer_ctx_get_async_events()
+{
+    struct ra_ctx_handle ctx_handle = {0};
+    struct async_event events[1] = {0};
+    unsigned int num = 1;
+    int ret = 0;
+
+    ret = ra_peer_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, 0);
+
+    mocker(rs_ctx_get_async_events, 1, -1);
+    ret = ra_peer_ctx_get_async_events(&ctx_handle, events, &num);
+    EXPECT_INT_EQ(ret, -1);
+    mocker_clean();
+}
+
+void tc_ra_rs_ctx_get_async_events()
+{
+    union op_ctx_get_async_events_data data_out = {0};
+    union op_ctx_get_async_events_data data_in = {0};
+
+    int rcv_buf_len = 0;
+    int op_result;
+    int out_len;
+    int ret;
+
+    char* in_buf = calloc(1, sizeof(struct MsgHead) + sizeof(union op_ctx_get_async_events_data));
+    char* out_buf = calloc(1, sizeof(struct MsgHead) + sizeof(union op_ctx_get_async_events_data));
+
+    data_in.tx_data.phy_id = 0;
+    data_in.tx_data.dev_index = 0;
+    memcpy_s(in_buf + sizeof(struct MsgHead), sizeof(union op_ctx_get_async_events_data),
+        &data_in, sizeof(union op_ctx_get_async_events_data));
+    data_in.tx_data.num = ASYNC_EVENT_MAX_NUM;
+    mocker(rs_ctx_get_async_events, 1, 0);
+    ret = ra_rs_ctx_get_async_events(in_buf, out_buf, &out_len, &op_result, rcv_buf_len);
+    EXPECT_INT_EQ(op_result, 0);
+    mocker_clean();
+
+    mocker(rs_ctx_get_async_events, 1, -1);
+    ret = ra_rs_ctx_get_async_events(in_buf, out_buf, &out_len, &op_result, rcv_buf_len);
+    EXPECT_INT_EQ(op_result, -1);
+    mocker_clean();
+
+    free(in_buf);
+    in_buf = NULL;
+    free(out_buf);
+    out_buf = NULL;
+}
