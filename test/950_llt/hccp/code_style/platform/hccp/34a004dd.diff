+ */
+#ifndef CCU_U_COMM_H
+#define CCU_U_COMM_H
+
+#include <stdbool.h>
+
+#define CCU_DATA_TYPE_UNION_ARRAY_SIZE 8
+#define CCU_RESOURCE_PATH_LEN_MAX 512
+#define CCU_DATA_MAX_SIZE 0x800  /* CCU data max size is 2048 */
+#define BYTE8   8
+#define BYTE32 32
+#define BYTE64 64
