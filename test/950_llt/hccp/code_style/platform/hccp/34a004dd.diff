+    hccp_err("rs_ping_urma_find_target_node i:%u failed, ret:%d eid:%016llx:%016llx jettyId:%u phyId:%u",i, ret,
+        target.eid.in6.subnetPrefix, target.eid.in6.interfaceId, jettyId.id, phyId);
+}
