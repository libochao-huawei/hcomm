+#endif
+
+enum ccu_array_data_index {
+    CCU_ARRAY_DATA_0 = 0,
+    CCU_ARRAY_DATA_1,
+    CCU_ARRAY_DATA_2,
+    CCU_ARRAY_DATA_3,
+    CCU_ARRAY_DATA_4,
+    CCU_ARRAY_DATA_5,
+    CCU_ARRAY_DATA_6,
+    CCU_ARRAY_DATA_7,
+};
+
+/* opcode definition */
