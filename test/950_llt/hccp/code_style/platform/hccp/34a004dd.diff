+    CCU_U_OP_SET_INSTRUCTION                = 251,  /* 设置INS指令 */
+    CCU_U_OP_SET_GSA                        = 252,  /* 设置GSA数据 */
+    CCU_U_OP_SET_XN                         = 253,  /* 设置XN数据 */
