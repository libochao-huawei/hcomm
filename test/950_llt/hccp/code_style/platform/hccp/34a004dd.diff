+    hccp_run_info("eid:%016llx:%016llx init jfce success, fd:%d", pingCb->udevCb.eidInfo.eid.in6.subnetPrefix,
+        pingCb->udevCb.eidInfo.eid.in6.interfaceId, jettyCb->jfce->fd);
