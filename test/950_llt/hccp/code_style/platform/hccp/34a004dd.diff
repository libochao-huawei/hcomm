+        unsigned int ids[HCCP_MAX_QP_DESTROY_BATCH_NUM]; 
+        unsigned int num;
+        unsigned int rsvd[4U];
+    } txData;
+
+    struct {
+        unsigned int num;
+        unsigned int rsvd[4U];
+    } rxData;
+};
+
