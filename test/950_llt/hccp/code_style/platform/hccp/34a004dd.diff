+STATIC bool RsPingCommonCompareUbInfo(struct PingQpInfo *a, struct PingQpInfo *b)
+{
+    if (a->ub.size != b->ub.size) {
+        return false;
+    }
+    if (memcmp(&a->ub.key, &b->ub.key, sizeof(a->ub.key)) != 0) {
