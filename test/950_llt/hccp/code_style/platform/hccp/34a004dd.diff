+{
+    if (gCcuApiHandle == NULL || gCcuOps.rsCcuUninit == NULL) {
+#ifndef CA_CONFIG_LLT
+        hccp_err("g_ccu_api_handle is NULL or RsCcuUninit is NULL");
+        return -EINVAL;
+#endif
+    }
+    return gCcuOps.rsCcuUninit();
+}
