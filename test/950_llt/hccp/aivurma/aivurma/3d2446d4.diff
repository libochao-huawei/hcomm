@@ -0,0 +1,61 @@
+/*
+* Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+* Description: header file of network adapt driver pagewalk
+* Create: 2025-12-16
+*/
+#ifndef NET_ADAPT_PGWALK_H
+#define NET_ADAPT_PGWALK_H
+
+#include <asm/pgtable.h>
+#include <asm/page.h>
+#include <linux/mm_types.h>
+#include "net_adapt_apm_api.h"
+
+#define NET_GPAGE_SHIFT             PUD_SHIFT
+#define NET_GPAGE_SIZE              (1ULL << NET_GPAGE_SHIFT)
+
+enum net_pte_level {
+    NET_PGD_LEVEL = 0U,
+    NET_P4D_LEVEL,
+    NET_PUD_LEVEL,
+    NET_PMD_LEVEL,
+    NET_FINAL_LEVEL,
+    NET_MAX_LEVEL
+};
+
+struct net_pgwalk {
+    struct vm_area_struct *vma;
+    struct net_pgwalk_ops *ops;
+    void *priv;
+};
+
+/**
+ * struct net_pgwalk_ops - callbacks for net_walk_page_range
+ * @pud_entry_post: if set, called for each non-empty PUD entry after walk next level PD
+ * @pmd_entry:      if set, called for each non-empty PMD entry
+ * @pte_entry:      if set, called for each non-empty PTE entry
+ * @pte_hole:       if set, called for each hole at all levels
+ */
+struct net_pgwalk_ops {
+    int (*pud_entry_post)(pud_t *pud, u64 addr, u64 next, struct net_pgwalk *walk);
+    int (*pmd_entry)(pmd_t *pmd, u64 addr, u64 next, struct net_pgwalk *walk);
+    int (*pte_entry)(pte_t *pte, u64 addr, u64 *next, enum net_pte_level level, struct net_pgwalk *walk);
+    int (*pte_hole)(u64 addr, u64 next, enum net_pte_level level, struct net_pgwalk *walk);
+};
+
+int net_walk_page_range(struct vm_area_struct *vma, u64 start, u64 end, struct net_pgwalk_ops *ops, void *priv);
+
+static inline u64 net_pte_level_to_page_size(enum net_pte_level level)
+{
+    u64 pte_level_to_page_size[NET_MAX_LEVEL] = {
+        [NET_PGD_LEVEL] = 0ULL,
+        [NET_P4D_LEVEL] = 0ULL,
+        [NET_PUD_LEVEL] = NET_GPAGE_SIZE,
+        [NET_PMD_LEVEL] = HPAGE_SIZE,
+        [NET_FINAL_LEVEL] = PAGE_SIZE
+    };
+
+    return pte_level_to_page_size[level];
+}
+
+#endif // NET_ADAPT_PGWALK_H
