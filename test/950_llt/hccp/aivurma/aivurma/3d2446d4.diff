+/*
+* Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+* Description: instance file of network adapt apm api
+* Create: 2025-12-18
+*/
+#include <linux/types.h>
+#include <linux/sched.h>
+#include <linux/mm.h>
+#include <linux/mm_types.h>
+#include <linux/version.h>
+#include <linux/preempt.h>
+
+#include "kernel_version_adapt.h"
+#include "net_adapt_sched.h"
+
+void net_try_cond_resched_by_time(unsigned long *pre_stamp, unsigned long time)
+{
+    unsigned long timeinterval;
+
+    if (in_atomic()) {
+        return;
+    }
+
+    timeinterval = jiffies_to_msecs(jiffies - *pre_stamp);
+    if (timeinterval > time) {
+        cond_resched();
+        *pre_stamp = jiffies;
+    }
+}
+
+void net_try_cond_resched(unsigned long *pre_stamp)
+{
+    net_try_cond_resched_by_time(pre_stamp, 500);   /* 500ms */
+}
