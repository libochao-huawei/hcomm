 */
 
 #include <ub/ubus/ubus.h>
+#include <linux/align.h>
 #include "ccu_cmd.h"
 #include "ccu_log.h"
 #include "ccu_cdev.h"
@@ -253,3 +254,42 @@ int ccu_cmd_set_tranm_ntf_hval(struct ccu_dev *ccudev, u32 tranm_ntf_hval)
 
     return 0;
 }
+
+int ccu_cmd_get_ccu_va(struct ccu_dev *ccudev, u32 *ccu_va_high, u32 *ccu_va_low)
+{
+    struct ccu_get_wqebb_va_cmd *resp = NULL;
+    u64 sq_size_per_fe, sq_va_start;
+    struct ccu_cmdq_desc desc = {0};
+    u32 die_num, ue_num, die_id;
+    u64 va_start, va_size;
+    u64 ccu_va = 0;
+    int ret = 0;
+ 
+    ccu_cmd_setup_basic_desc(&desc, CCU_OPC_GET_WQEBB_VA, true, 1);
+    ret = ccu_send_cmd(ccudev, &desc, 1);
+    CHK_PRT_RETURN(ret != 0, ccu_drv_err("failed to send command, ret = %d.\n", ret), ret);
+ 
+    resp = (struct ccu_get_wqebb_va_cmd *)desc.data;
+    va_start = le64_to_cpu(resp->va_start);
+    va_size = le64_to_cpu(resp->va_size);
+    die_num = le32_to_cpu(resp->die_num);
+    ue_num = le32_to_cpu(resp->ue_num);
+    die_id = ccudev->die_id;
+ 
+    CHK_PRT_RETURN(die_num == 0 || ue_num == 0, ccu_drv_err("die_num(%u) or ue_num(%u) is zero\n",
+        die_num, ue_num), -EINVAL);
+ 
+    ccu_drv_info("va_start(0x%llx) va_size(0x%llx) die_num(%u) ue_num(%u) die_id(%u) ue_id(%u)\n",
+        va_start, va_size, die_num, ue_num, die_id, ccudev->ue_id);
+ 
+    sq_size_per_fe = ALIGN_DOWN(va_size / die_num / ue_num, SQ_SIZE_PER_JETTY);
+    // sq_va_start = va_start + sq_size_per_fe * (ccudev->ue_id - TWO + die_id * ue_num);
+    // ccu_va = sq_va_start + (CCU_JETTY_START_ID * SQ_SIZE_PER_JETTY);
+    sq_va_start = va_start + va_size;
+    ccu_va = sq_va_start + die_id * 80 * 1024 * 1024;
+    ccu_drv_info("sq_size_per_fe(0x%llx) sq_va_start(0x%llx) ccu_va(0x%llx)\n", sq_size_per_fe, sq_va_start, ccu_va);
+ 
+    *ccu_va_high = upper_32_bits(ccu_va);
+    *ccu_va_low = lower_32_bits(ccu_va);
+    return 0;
+}
