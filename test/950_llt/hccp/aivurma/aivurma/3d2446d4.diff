+ 
+    pid = get_pid(find_pid_ns(tgid, &init_pid_ns));
+    if (pid == NULL) {
+        return NULL;
+    }
+ 
+    task = get_pid_task(pid, PIDTYPE_PID);
+    put_pid(pid);
+ 
+    return task;
+}
+ 
+STATIC inline struct task_struct *net_task_get_by_tgid(int tgid)
+{
+    struct task_struct *task = NULL;
+ 
+    rcu_read_lock();
+    task = _net_task_get_by_tgid(tgid);
+    rcu_read_unlock();
+ 
+    return task;
+}
+ 
+struct page *net_pa_to_page(u64 pa)
+{
+    u64 pfn = (unsigned long)PFN_DOWN(pa);
+    return pfn_to_page(pfn);
+}
+ 
+STATIC void net_unpin_npages(struct page **pages, u64 page_num, u64 unpin_num, u32 res_type)
+{
+    unsigned long stamp;
+    u64 i;
+ 
+    if ((unpin_num > page_num) || (pages == NULL) || (res_type != RES_ADDR_TYPE_HCCP_URMA_JETTY) || (res_type != RES_ADDR_TYPE_HCCP_URMA_JFC)) {
+        return;
+    }
+ 
+    stamp = jiffies;
+    net_drv_info("[chydebug]net_unpin_npages, unpin_num(%u)\n", unpin_num);
+    for (i = 0; i < unpin_num; i++) {
+        if (pages[i] != NULL) {
+            put_page(pages[i]);
+            pages[i] = NULL;
+        }
+        net_try_cond_resched(&stamp);
+    }
+}
+ 
+STATIC void net_pin_npages(u64 pa, struct net_pgwalk_data_of_query_phys *data)
+{
+    struct page *page = NULL;
+ 
+    if (data->res_type != RES_ADDR_TYPE_HCCP_URMA_JETTY || (data->res_type != RES_ADDR_TYPE_HCCP_URMA_JFC)) {
+        return;
+    }
+ 
+    if (data->pin_npages.got_num >= data->seg_num) {
+        net_drv_err("no buffer error, data->pin_npages.got_num(%u) >= seg_num(%u)",
+            data->pin_npages.got_num, data->seg_num);
+        return;
+    }
+ 
+    page = net_pa_to_page(pa);
+    net_drv_info("[chydebug]net_pin_npages, pa(0x%llx) page(0x%llx)\n", pa, page);
+    get_page(page);
+    data->pin_npages.pages[data->pin_npages.got_num] = page;
+    data->pin_npages.got_num++;
+}
+ 
+STATIC bool net_pa_is_local_mem(u64 pa)
+{
+    return page_is_ram(PFN_DOWN(pa));
+}
+ 
+STATIC void net_get_pa(pte_t *pte, u64 addr, u64 page_size, u64 *page_offset, u64 *pa, bool *local_mem_flag)
+{
+    u64 pfn;
+ 
+    *page_offset = addr - round_down(addr, page_size);
+    pfn = (u64)pte_pfn(*pte);
+    *pa = (unsigned long)PFN_PHYS(pfn);
+    *pa += *page_offset;
+    *local_mem_flag = net_pa_is_local_mem(*pa);
+}
+ 
+STATIC int net_pte_entry_of_query_phys(pte_t *pte, u64 addr, u64 *next, enum net_pte_level level,
+    struct net_pgwalk *walk)
+{
+    struct net_pgwalk_data_of_query_phys *data = (struct net_pgwalk_data_of_query_phys *)walk->priv;
+    u64 page_size, page_offset;
+    bool cur_local_mem_flag;
+    u64 page_4k_num = 0;
+    u64 mem_size = 0;
+    u64 pa, i;
+ 
+    page_size = net_pte_level_to_page_size(level);
+    if (page_size == 0ULL) {
+        net_drv_err("level(%u) is invalid\n", level);
+        goto unpin_npages;
+    }
+ 
+    net_drv_info("[chydebug]net_pte_entry_of_query_phys, pte(0x%llx) va(0x%llx) next(0x%llx) level:%u page_size:0x%x\n", pte, addr, *next, level, page_size);
+    page_4k_num = round_up(mem_size, PAGE_SIZE) / PAGE_SIZE;
+    net_get_pa(pte, addr, page_size, &page_offset, &pa, &cur_local_mem_flag);
+ 
+    if (data->queried_seg_num == 0ULL) {
+        data->is_local_mem = cur_local_mem_flag;
+    }
+
+    if (*next - addr == page_size) {
+        *next -= page_offset; // Ensure the second pa is 4K page aligned
+    }
+
+    mem_size = *next - addr;
+    page_4k_num = round_up(mem_size, PAGE_SIZE) / PAGE_SIZE;
+    if (data->is_local_mem != cur_local_mem_flag) {
+        net_drv_err("query pa is mixed local and remote, data->is_local_mem(%d), cur_local_mem_flag(%d)\n",
+            data->is_local_mem, cur_local_mem_flag);
+        goto unpin_npages;
+    }
+ 
+    if (data->queried_seg_num + page_4k_num > data->seg_num) {
+        net_drv_err("The pa array does not have enough space, queried_seg_num(%u) + page_4k_num(%u) > seg_num(%u)",
+            data->queried_seg_num, page_4k_num, data->seg_num);
+        goto unpin_npages;
+    }
+ 
+    for (i = 0; i < page_4k_num; i++) { // cut into 4K pages
+        data->pa[data->queried_seg_num + i] = pa + i * PAGE_SIZE;
+    }
+    data->queried_seg_num += page_4k_num;
+    data->queried_seg_size += mem_size;
+    net_drv_info("[chydebug]net_pte_entry_of_query_phys, va(0x%llx), get pa(0x%llx), seg_num(%u) seg_size(0x%llx)\n",
+        addr, pa, data->queried_seg_num, data->queried_seg_size);
+    net_pin_npages(pa, data);
+    return 0;
+ 
+unpin_npages:
+    net_unpin_npages(data->pin_npages.pages, data->seg_num, data->pin_npages.got_num, data->res_type);
+    return -EFAULT;
+}
+ 
+STATIC int net_pte_hole_of_query_pfn(u64 addr, u64 next, enum net_pte_level level, struct net_pgwalk *walk)
+{
+    struct net_pgwalk_data_of_query_phys *data = (struct net_pgwalk_data_of_query_phys *)walk->priv;
+ 
+    net_drv_err("Va to pa failed.\n");
+    net_unpin_npages(data->pin_npages.pages, data->seg_num, data->pin_npages.got_num, data->res_type);
+    return -EFAULT;
+}
+ 
+STATIC u64 net_adapt_query_phys(struct vm_area_struct *vma, u64 va, u64 size, struct net_pgwalk_data_of_query_phys *data)
+{
+    struct net_pgwalk_ops ops = {NULL};
+    struct page **pages = NULL;
+ 
+    pages = (struct page **)kzalloc((data->seg_num) * sizeof(struct page *), GFP_KERNEL);
+    CHK_PRT_RETURN(pages == NULL, net_drv_err("alloc pages failed\n"), 0); // 0 indicates that no pa was found
+ 
+    data->pin_npages.pages = pages;
+    ops.pte_hole = net_pte_hole_of_query_pfn;
+    ops.pte_entry = net_pte_entry_of_query_phys;
+    (void)net_walk_page_range(vma, va, va + size, &ops, (void *)data);
+ 
+    kfree(pages);
+    pages = NULL;
+    net_drv_info("[chydebug]queried_seg_size(0x%llx)\n", data->queried_seg_size);
+
+    return data->queried_seg_size;
+}
+ 
+STATIC int net_adapt_res_param_check(struct res_map_info_in *res_info, u64 pa[], struct net_adapt_va_info **va_info)
+{
+    CHK_PRT_RETURN((res_info == NULL) || (pa == NULL), net_drv_err("res_info or pa is NULL\n"), -EINVAL);
+ 
+    net_drv_info("[chydebug]net_adapt_res_param_check start, priv(%p)", res_info->priv);
+
+    *va_info = (struct net_adapt_va_info *)res_info->priv;
+    CHK_PRT_RETURN(va_info == NULL, net_drv_err("priv is NULL\n"), -EINVAL);
+    CHK_PRT_RETURN((res_info->priv_len == 0) || (res_info->priv_len > sizeof(struct net_adapt_va_info)),
+        net_drv_err("res_info->priv_len is zero or too large\n"), -EINVAL);
+ 
+    return 0;
+}
+ 
+int net_adapt_get_res_addr_array(u32 udevid, struct res_map_info_in *res_info, u64 pa[], u32 num, u32 *len)
+{
+    struct net_pgwalk_data_of_query_phys data = {0};
+    struct net_adapt_va_info *va_info = NULL;
+    struct vm_area_struct *vma = NULL;
+    struct task_struct *task = NULL;
+    struct mm_struct *mm = NULL;
+    u64 queried_size = 0;
+    int ret = 0;
+ 
+    net_drv_info("[chydebug]net_adapt_get_res_addr_array start");
+    ret = net_adapt_res_param_check(res_info, pa, &va_info);
+    CHK_PRT_RETURN(ret != 0, net_drv_err("net_adapt_res_param_check fail\n"), -EINVAL);
+    CHK_PRT_RETURN(len == NULL, net_drv_err("len is NULL\n"), -EINVAL);
+ 
+    net_drv_info("[chydebug]net_adapt_get_res_addr_array pid(%d)", va_info->pid);
+    task = net_task_get_by_tgid(va_info->pid);
+    CHK_PRT_RETURN(task == NULL, net_drv_err("get task failed, pid(%d) res_type(%u)\n",
+        va_info->pid, va_info->type), -EINVAL);
+    mm = get_task_mm(task);
+    if (mm == NULL) {
+        net_drv_err("get_task_mm failed, pid(%d)\n", va_info->pid);
+        goto out_put_task;
+    }
+ 
+    mmap_read_lock(mm);
+    vma = find_vma(mm, va_info->va);
+    if (vma == NULL) {
+        net_drv_err("find_vma failed\n");
+        ret = -EIO;
+        goto out_put_mm;
+    }
+
+    net_drv_info("[chydebug]net_adapt_get_res_addr_array, udevid(%u) res_type(%u) va(0x%llx) len(0x%llx) num(%u)",
+        udevid, res_info->res_type, va_info->va, va_info->size, num);
+    data.pa = pa;
+    data.seg_num = num;
+    data.res_type = va_info->type;
+    queried_size = net_adapt_query_phys(vma, va_info->va, va_info->size, &data);
+    *len = (u32)queried_size;
+    net_drv_info("[chydebug]res_type(%u) len(0x%x) va_size(0x%llx)", res_info->res_type, *len, va_info->size);
+    if (queried_size != va_info->size) {
+        net_drv_err("Query pa failed, va_size(0x%llx) queried_size(0x%llx)\n", va_info->size, queried_size);
+        ret = -EFAULT;
+        goto out_put_mm;
+    }
+ 
+out_put_mm:
+    mmap_read_unlock(mm);
+    mmput(mm);
+out_put_task:
+    put_task_struct(task);
+    return ret;
+}
+ 
+void net_adapt_put_res_addr_array(u32 udevid, struct res_map_info_in *res_info, u64 pa[], u32 len)
+{
+    u32 shift = HPAGE_SIZE / PAGE_SIZE;
+    struct page **pages = NULL;
+    u32 page_4k_num = 0;
+    u32 i, unpin_num;
+ 
+    net_drv_info("[chydebug]net_adapt_put_res_addr_array start");
+    CHK_PRT_RETURN((res_info == NULL) || (pa == NULL), net_drv_err("res_info or pa is NULL\n"), -EINVAL);
+ 
+    page_4k_num = round_up((pa[0] % PAGE_SIZE) + len, PAGE_SIZE) / PAGE_SIZE;
+    net_drv_info("[chydebug]put_res_addr_array,udevid(%u) res_type(%u) len(0x%x) page_num(%u)",udevid, res_info->res_type, len, page_4k_num);
+    pages = (struct page **)kzalloc(page_4k_num * sizeof(struct page *), GFP_KERNEL);
+    if (pages == NULL) {
+        net_drv_err("alloc pages failed\n");
+        return;
+    }
+ 
+    for (i = 0, unpin_num = 0; i < page_4k_num; i += shift, unpin_num++) {
+        pages[unpin_num] = net_pa_to_page(pa[i]);
+    }
+    net_unpin_npages(pages, (u64)unpin_num, (u64)unpin_num, res_info->res_type);
+    kfree(pages);
+    pages = NULL;
+    return;
+}
+ 
+STATIC struct apm_res_map_ops net_adapt_apm_ops = {
+    .owner = NULL,
+    .res_is_belong_to_proc = NULL,
+    .get_res_addr_array = net_adapt_get_res_addr_array,
+    .put_res_addr_array = net_adapt_put_res_addr_array,
+};
+ 
+int net_apm_ops_reg(void)
+{
+    enum res_addr_type net_res_type;
+    int ret;
+ 
+    net_res_type = RES_ADDR_TYPE_HCCP_URMA_JETTY;
+    ret = hal_kernel_apm_res_map_ops_register(net_res_type, &net_adapt_apm_ops);
+    CHK_PRT_RETURN(ret != 0, net_drv_err("hal_kernel_apm_res_map_ops_register failed, res_type:%u ret:%d\n",
+        net_res_type, ret), -EINVAL);
+ 
+    net_res_type = RES_ADDR_TYPE_HCCP_URMA_DB;
+    ret = hal_kernel_apm_res_map_ops_register(net_res_type, &net_adapt_apm_ops);
+    CHK_PRT_RETURN(ret != 0, net_drv_err("hal_kernel_apm_res_map_ops_register failed, res_type:%u ret:%d\n",
+        net_res_type, ret), -EINVAL);
+ 
+    net_res_type = RES_ADDR_TYPE_HCCP_URMA_JFC;
+    ret = hal_kernel_apm_res_map_ops_register(net_res_type, &net_adapt_apm_ops);
+    CHK_PRT_RETURN(ret != 0, net_drv_err("hal_kernel_apm_res_map_ops_register failed, res_type:%u ret:%d\n",
+        net_res_type, ret), -EINVAL);
+
+    return 0;
+}
