@@ -0,0 +1,283 @@
+/*
+* Copyright (c) Huawei Technologies Co., Ltd. 2025. All rights reserved.
+* Description: instance file of network adapt driver pagewalk
+* Create: 2025-12-16
+*/
+#include <asm/pgtable.h>
+#include <asm/page.h>
+#include <linux/version.h>
+#include <linux/mm_types.h>
+#include <linux/swap.h>
+#include <linux/swapops.h>
+#include "net_adapt_sched.h"
+#include "net_adapt_pgtable_def.h"
+#include "net_adapt_log.h"
+#include "net_adapt_pgwalk.h"
+
+#ifndef CONFIG_LLT
+STATIC pte_t *net_pte_offset_map(pmd_t *pmd, u64 addr)
+{
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 5, 0)
+    pmd_t pmdval;
+
+    /* rcu_read_lock() to be added later */
+    pmdval = pmdp_get_lockless(pmd);
+    if (unlikely(pmd_none(pmdval) || is_pmd_migration_entry(pmdval))) {
+        goto nomap;
+    }
+    if (unlikely(pmd_trans_huge(pmdval) || pmd_devmap(pmdval))) {
+        goto nomap;
+    }
+    if (unlikely(pmd_bad(pmdval))) {
+        pmd_ERROR(*pmd);
+        pmd_clear(pmd);
+        goto nomap;
+    }
+    return __pte_map(&pmdval, addr);
+
+nomap:
+    /* rcu_read_unlock() to be added later */
+    return NULL;
+#else
+    return pte_offset_map(pmd, addr);
+#endif
+}
+
+STATIC int net_walk_pte_range(pmd_t *pmd, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    unsigned long stamp = jiffies;
+    struct net_pgwalk_ops *ops = walk->ops;
+    pte_t *pte = NULL;
+    u64 next = start;
+    int ret = 0;
+
+    pte = net_pte_offset_map(pmd, start);
+    do {
+        net_try_cond_resched(&stamp);
+        next = net_adapt_min(next + PAGE_SIZE, end);
+        if ((pte != NULL) && (pte_none(*pte) == 0) && (pte_present(*pte) != 0)) {
+            if (ops->pte_entry != NULL) {
+                ret = ops->pte_entry(pte, start, &next, NET_FINAL_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+        } else {
+            net_drv_info("[chydebug]pte(0x%llx) next(0x%llx) start(0x%llx) end(0x%llx) level(%u)",
+                pte, next, start, end, NET_FINAL_LEVEL);
+            if (ops->pte_hole != NULL) {
+                ret = ops->pte_hole(start, next, NET_FINAL_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+        }
+        // cppcheck-suppress *
+    } while (pte++, start = next, start != end);
+
+    return ret;
+}
+
+STATIC int net_walk_pmd_range(pud_t *pud, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    struct net_pgwalk_ops *ops = walk->ops;
+    unsigned long stamp = jiffies;
+    pmd_t *pmd = NULL;
+    int ret = 0;
+    u64 next;
+
+    pmd = pmd_offset(pud, start);
+    do {
+        net_try_cond_resched(&stamp);
+        next = pmd_addr_end(start, end);
+        if (PMD_HUGE(pmd)) { /* is huge page */
+            if (ops->pte_entry != NULL) {
+                ret = ops->pte_entry((pte_t *)pmd, start, &next, NET_PMD_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        } else if (PXD_JUDGE(pmd)) {
+            net_drv_info("[chydebug]pmd(0x%llx) next(0x%llx) start(0x%llx) end(0x%llx) level(%u)",
+                pmd, next, start, end, NET_PMD_LEVEL);
+            if (ops->pte_hole != NULL) {
+                ret = ops->pte_hole(start, next, NET_PMD_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        }
+
+        if (ops->pmd_entry != NULL) {
+            ret = ops->pmd_entry(pmd, start, next, walk);
+            if (ret != 0) {
+                break;
+            }
+        }
+
+        if ((ops->pte_entry != NULL) || (ops->pte_hole != NULL)) {
+            ret = net_walk_pte_range(pmd, start, next, walk);
+            if (ret != 0) {
+                break;
+            }
+        }
+        // cppcheck-suppress *
+    } while (pmd++, start = next, start != end);
+
+    return ret;
+}
+
+STATIC int _net_walk_pud_range(pud_t *pud, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    struct net_pgwalk_ops *ops = walk->ops;
+    unsigned long stamp = jiffies;
+    int ret = 0;
+    u64 next;
+
+    do {
+        net_try_cond_resched(&stamp);
+        next = pud_addr_end(start, end);
+        if (PUD_GIANT(pud)) { /* is giant page */
+            if (ops->pte_entry != NULL) {
+                ret = ops->pte_entry((pte_t *)pud, start, &next, NET_PUD_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        } else if (PXD_JUDGE(pud)) {
+            net_drv_info("[chydebug]next(0x%llx) start(0x%llx) end(0x%llx) level(%u) pud(0x%llx)", next, start, end, NET_PMD_LEVEL, pud);
+            if (ops->pte_hole != NULL) {
+                ret = ops->pte_hole(start, next, NET_PUD_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        }
+
+        if ((ops->pte_entry != NULL) || (ops->pte_hole != NULL) || (ops->pmd_entry != NULL)) {
+            ret = net_walk_pmd_range(pud, start, next, walk);
+            if (ret != 0) {
+                break;
+            }
+        }
+
+        if (ops->pud_entry_post != NULL) {
+            ret = ops->pud_entry_post(pud, start, next, walk);
+            if (ret != 0) {
+                break;
+            }
+        }
+
+        // cppcheck-suppress *
+    } while (pud++, start = next, start != end);
+
+    return ret;
+}
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(4, 11, 0)
+STATIC int net_walk_pud_range(p4d_t *p4d, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    return _net_walk_pud_range(pud_offset(p4d, start), start, end, walk);
+}
+
+STATIC int net_walk_p4d_range(pgd_t *pgd, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    struct net_pgwalk_ops *ops = walk->ops;
+    unsigned long stamp = jiffies;
+    p4d_t *p4d = NULL;
+    int ret = 0;
+    u64 next;
+
+    p4d = p4d_offset(pgd, start);
+    do {
+        net_try_cond_resched(&stamp);
+        next = p4d_addr_end(start, end);
+        if (PXD_JUDGE(p4d)) {
+            net_drv_info("[chydebug]next(0x%llx) start(0x%llx) end(0x%llx) level(%u) p4d(0x%llx)", next, start, end, NET_P4D_LEVEL, p4d);
+            if (ops->pte_hole != NULL) {
+                ret = ops->pte_hole(start, next, NET_P4D_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        }
+
+        ret = net_walk_pud_range(p4d, start, next, walk);
+        if (ret != 0) {
+            break;
+        }
+        // cppcheck-suppress *
+    } while (p4d++, start = next, start != end);
+
+    return ret;
+}
+#else
+STATIC int net_walk_pud_range(pgd_t *pgd, u64 start, u64 end, struct net_pgwalk *walk)
+{
+    return _net_walk_pud_range(pud_offset(pgd, start), start, end, walk);
+}
+#endif
+
+STATIC int net_walk_pgd_range(u64 start, u64 end, struct net_pgwalk *walk)
+{
+    struct vm_area_struct *vma = walk->vma;
+    struct net_pgwalk_ops *ops = walk->ops;
+    unsigned long stamp = jiffies;
+    pgd_t *pgd = NULL;
+    int ret = 0;
+    u64 next;
+
+    pgd = pgd_offset(vma->vm_mm, start);
+    do {
+        net_try_cond_resched(&stamp);
+        next = pgd_addr_end(start, end);
+        if (PXD_JUDGE(pgd)) {
+            net_drv_info("[chydebug]pgd(0x%llx) next(0x%llx) start(0x%llx) end(0x%llx) level(%u)", pgd, next, start, end, NET_PGD_LEVEL);
+            if (ops->pte_hole != NULL) {
+                ret = ops->pte_hole(start, next, NET_PGD_LEVEL, walk);
+                if (ret != 0) {
+                    break;
+                }
+            }
+            continue;
+        }
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(4, 11, 0)
+        ret = net_walk_p4d_range(pgd, start, next, walk);
+#else
+        ret = net_walk_pud_range(pgd, start, next, walk);
+#endif
+        if (ret != 0) {
+            break;
+        }
+        // cppcheck-suppress *
+    } while (pgd++, start = next, start != end);
+
+    return ret;
+}
+
+int net_walk_page_range(struct vm_area_struct *vma, u64 start, u64 end, struct net_pgwalk_ops *ops, void *priv)
+{
+    struct net_pgwalk walk = {
+        .vma = vma,
+        .ops = ops,
+        .priv = priv
+    };
+
+    if (start >= end) {
+        return -EFAULT;
+    }
+
+    return net_walk_pgd_range(start, end, &walk);
+}
+#else
+/* For ut file coverage */
+void net_adapt_pgwalk(void)
+{
+}
+#endif
