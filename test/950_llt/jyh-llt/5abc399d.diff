+    extMsg->sendCounts[1] = extMsg->sendOffset[1] = extMsg->recvCounts[1] = extMsg->recvOffset[1] = 999;
+    extMsg->valid = HCCL_MSG_VALID_MASK;
+    extMsg->xorCheck = GenXorStub(extMsg, 2);
