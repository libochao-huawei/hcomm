+    // group sync
+    syncMsg->commType = HCCL_CMD_INTER_GROUP_SYNC;
+    syncMsg->commDepGroupID = 1;
+    syncMsg->commDepHandleID = 1;
+    syncMsg->valid = HCCL_MSG_VALID_MASK;
+    syncMsg->xorCheck = GenXorStub(syncMsg);
