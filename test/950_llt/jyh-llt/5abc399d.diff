+    ++msg;
+    msg->version = 3;
+    msg->commType = HCCL_CMD_FINALIZE;
+    msg->valid = HCCL_MSG_VALID_MASK;
+    msg->xorCheck = GenXorStub((HcclMsgForTest *)msg);
+
+    // commit
+    msg = (HcclMsgV1ForTest *)&(((HcclMsgAreaForTest *)g_msgAreaBak)->sendMsgList[0]);
+    msg->version = 3;
+    msg->commType = HCCL_CMD_ALLREDUCE;
