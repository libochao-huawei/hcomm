# HCCL-VM 一键安装：装依赖 -> 检测 CANN -> 拉取公开源码(hcomm/hccl) -> 编译。
#
# ============================ 依赖关系说明 ============================
# 组件角色：
#   CANN 包(用户提供)      : 终态发布包；内含编译好的 hcomm/hccl 库(.so)、对外导出头
#                           (如 hccl_res_expt.h 中的 ThreadType 等类型)、ACL runtime。
#   hcomm 源码(脚本 clone) : ① 承载 checker 本体(即 test/hccl_vm)；② 提供 hcomm 内部
#                           源码(src/platform、framework、base_comm…)供 checker 编译。
#   hccl 源码(脚本 clone)  : 提供 hccl 内部源码(src/ops、hcomm_dlsym…)供 checker 编译
#                           device/AICPU/AIV。上述内部源码 CANN 包里不包含。
#
# 官方(正常)配套方向：CANN 版本为锚 -> hcomm/hccl 源码用与该 CANN 版本一致的发布
#   tag(见 release-management 的 cann-hcomm/cann-hccl 行)。即“源码跟随 CANN”。
#
# 本工具的配套：checker 存在于 hcomm 的竞赛/主线分支（发布 tag 里没有 checker）。默认按
#   profile competition/campus-2026 取 hcomm/hccl 同一竞赛分支；CANN 版本由该分支 build.md
#   提取（见 --list-profiles）。源码与 CANN 需同代配套，不配套时 device 侧会因缺新接口
#   (如 ThreadType)编译失败，本脚本会在失败时提示更换配套 CANN。
# ====================================================================
set -euo pipefail

# 颜色（仅 stdout 为终端时启用；被管道/重定向时关闭，避免日志里出现乱码转义）
color_enabled() { [ -t 1 ]; }
if color_enabled; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; NC=''
fi

# 全局变量（可由环境变量或命令行覆盖）
WORKSPACE=${WORKSPACE:-}
ASCEND_PATH=${ASCEND_PATH:-/usr/local/Ascend}
HCOMM_PATH=${HCOMM_PATH:-}
HCCL_PATH=${HCCL_PATH:-}
CHECKER_PATH=${CHECKER_PATH:-}
# 分支引用：不在此写死默认，默认由 profile 落定（见 apply_defaults）。
# 记录“环境变量是否显式提供”，用于优先级链 CLI > env > profile。
ENV_HCOMM_REF="${HCOMM_REF:-}"
ENV_HCCL_REF="${HCCL_REF:-}"
CLI_HCOMM_REF=""
CLI_HCCL_REF=""
HCOMM_REF=""
HCCL_REF=""
HCOMM_REF_SRC=""
HCCL_REF_SRC=""
PROFILE=""
PROFILE_CUSTOM=false
VERBOSE=false
CANN_MODE="auto"            # 内部 CANN 策略：auto(默认) | download(--reinstall-cann) | keep(--offline)
ASCEND_PATH_EXPLICIT=false  # --ascend-path 是否由用户显式传入
SKIP_HCCL_TEST=false        # --skip-hccl-test
WILL_DL=false               # 阶段①决策结果：稍后是否下载 CANN
CANN_INSTALLED=""           # detect_cann 写入：已探测到的现有 CANN 根目录（空=未探测到）
CANN_SETENV=""              # detect_cann 写入：对应的 set_env.sh 全路径（空=未探测到）
CANN_TARGET=""              # 解析出的安装目标目录（决定下载/覆盖时由 resolve_cann_target 赋值）
CANN_CACHE=""               # 下载缓存目录，apply_defaults 里赋 ${WORKSPACE}/.cann-download
CANN_RUN_FILE=""            # 实际下载到的 .run 文件全路径（收尾展示用）
CANN_CHANNEL="master"       # CANN 镜像下载通道，apply_defaults 按 profile 落定（campus=legacy / main=master）
HCCL_TEST_RESULT=""         # build_hccl_test 写入：built | skipped | failed:<原因>
HCCL_TEST_BIN_DIR=""        # build_hccl_test 写入：hccl_test 可执行文件所在目录（原地编译）
SUDO_PREFIX=""              # setup_sudo 解析：root 为空；非 root 有 sudo 为 "sudo"
SUDO_KEEPALIVE_PID=""       # sudo 授权保活后台进程 PID（cleanup_sudo 负责回收）
STEP_TOTAL=9                # 编译 HCCL-VM(7) → 编译安装子包(8) → 编译 hccl_test(9)
LOG_DIR=""
RUN_TS=""

# 版本标识（发布时更新；SCRIPT_COMMIT 可由同步流程回填，未知则保持 unknown）
SCRIPT_VERSION="1.0.0"
SCRIPT_COMMIT="unknown"



# 显示信息
info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

# 显示警告
warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

# 显示错误并退出
error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
    exit 1
}

# 步骤进度：[时:分:秒] [n/total] 消息
step() {
    echo -e "${GREEN}[$(date +%H:%M:%S)] [$1/$2]${NC} $3"
}
# 版本串：commit 已回填才带 commit，否则只显示版本号（避免露 "commit unknown"）
version_line() {
    if [ "${SCRIPT_COMMIT}" = "unknown" ]; then
        echo "v${SCRIPT_VERSION}"
    else
        echo "v${SCRIPT_VERSION} (commit ${SCRIPT_COMMIT})"
    fi
}
# 起始信息块（非 ASCII art）
banner() {
    info "HCCL-VM 一键安装 $(version_line)（工作目录: ${WORKSPACE}）"
    info "配套方案: ${PROFILE}"
    info "将分 ${STEP_TOTAL} 步自动完成依赖安装、源码拉取、CANN 配置与编译；总耗时取决于网络与机器性能。"
}
success_summary() {
    local bin="${CHECKER_PATH}/hccl_vm_install/bin/hccl-vm"
    info "HCCL-VM 安装完成。"
    info "checker 产物: ${bin}"
    info "CANN 路径: ${ASCEND_HOME_PATH:-未知}"
    info "HCCL/HCOMM 子包已编译安装到: ${ASCEND_HOME_PATH:-未知}"
    info "驱动依赖库已拷贝到: ${CHECKER_PATH}/hccl_vm_install/lib/aarch64/"
    case "${HCCL_TEST_RESULT}" in
        built)     info "hccl_test: 已编译 ${HCCL_TEST_BIN_DIR:-${WORKSPACE}/hccl_test/bin}/" ;;
        skipped)   info "hccl_test: 已跳过（--skip-hccl-test）" ;;
        failed:*)  warn "hccl_test: 未编译（${HCCL_TEST_RESULT#failed:}）" ;;
        *)         : ;;
    esac
    [ -n "${CANN_RUN_FILE}" ] && info "CANN 安装包（已保留）: ${CANN_RUN_FILE}"
    local inst="${CHECKER_PATH}/hccl_vm_install"
    local setenv="${ASCEND_HOME_PATH:-<CANN>/ascend-toolkit}/set_env.sh"
    if [ "${HCCL_TEST_RESULT}" = built ]; then
        info "后续步骤（可直接复制，运行一个 hccl_test 用例并由 checker 校验）:"
        echo "  source ${setenv}" >&2
        echo "  source ${inst}/script/hccl_config.sh   # 设 RANK_TABLE_FILE 等运行变量" >&2
        echo "  cd ${inst}/bin && ./hccl-vm start ascend950_cluster_32_server_normal.yaml" >&2
        echo "    (hvm)\$> hccl-vm mock-comm 112" >&2
        echo "    (hvm)\$> mpirun --allow-run-as-root --oversubscribe -np 2 ${HCCL_TEST_BIN_DIR:-${WORKSPACE}/hccl_test/bin}/alltoall_test -b 64 -e 64 -d int32 -o sum -w 0 -n 1 -c 1" >&2
        echo "    (hvm)\$> hccl-vm plugin run @checker" >&2
        echo "    (hvm)\$> exit" >&2
    else
        info "后续步骤（可直接复制）:"
        echo "  cd ${CHECKER_PATH} && source ${setenv} && ./hccl_vm_install/bin/hccl-vm start <集群配置文件>" >&2
    fi
    if [ -f "${CHECKER_PATH}/README-Competition.md" ]; then
        echo "  更多集群配置与用例见 ${CHECKER_PATH}/README-Competition.md §4" >&2
    elif [ -f "${CHECKER_PATH}/README.md" ]; then
        echo "  集群配置示例见 ${CHECKER_PATH}/README.md" >&2
    fi
}

# 检查 apt 包是否已安装（dpkg-query 精确查询，无管道，避免 dpkg -l|grep 在 pipefail 下被 SIGPIPE 误判）
check_package() {
    local status
    status="$(dpkg-query -W -f='${Status}' "$1" 2>/dev/null)" || return 1
    [ "$status" = "install ok installed" ]
}

# 判断操作系统是否受支持（仅 Linux）
is_supported_os() {
    [[ "$1" == "Linux" ]]
}

# 归一化 CPU 架构；未知架构返回非零
normalize_arch() {
    case "$1" in
        x86_64|amd64) echo "x86_64" ;;
        aarch64|arm64) echo "aarch64" ;;
        *) return 1 ;;
    esac
}

# ── Profile 注册表：一个 profile 只映射 hcomm/hccl 分支；首行为默认；新增版本加一行即可 ──
# 每行格式：hcomm_ref|hccl_ref|说明
profile_all_names() {
    printf '%s\n' "campus-2026" "main"
}
# 每行格式：hcomm_ref|hccl_ref|说明|是否允许 weekly|CANN 下载通道（master=滚动最新 / legacy=归档）
profile_row() {
    case "$1" in
        campus-2026) echo "competition/campus-2026|competition/campus-2026|竞赛固定，CANN 从 build.md 提取|false|legacy" ;;
        main)        echo "master|master|主线最新，随官方更新|true|master" ;;
        *) return 1 ;;
    esac
}
profile_default()      { profile_all_names | head -n 1; }
profile_exists()       { profile_row "$1" >/dev/null 2>&1; }
profile_hcomm_ref()    { profile_row "$1" | cut -d'|' -f1; }
profile_hccl_ref()     { profile_row "$1" | cut -d'|' -f2; }
profile_desc()         { profile_row "$1" | cut -d'|' -f3; }
profile_allow_weekly() { profile_row "$1" | cut -d'|' -f4; }   # 空/false 均视为不允许
profile_cann_channel() { profile_row "$1" | cut -d'|' -f5; }   # CANN 下载通道；空则由 apply_defaults 兜底 master

