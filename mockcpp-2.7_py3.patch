+    add_custom_command(
+        OUTPUT ${HEADER}
+        COMMAND ${PYTHON} ${ARG_GENERATOR} ${EXTRA_ARG_HEADERS_DEFS} ${HEADER_NAME}
+    )
+endforeach()
