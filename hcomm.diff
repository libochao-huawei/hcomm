+HcclResult DevCfgMulQpInfoCache::GetSpecialSourcePortsByIpPair(MulQpSourcePorts &sourcePorts,
+                                                               const KeyPair &ipPair) const
+{
+    (void)ipPair;
+    sourcePorts = cacheInfo_;
+    return HcclResult::HCCL_SUCCESS;
+}
